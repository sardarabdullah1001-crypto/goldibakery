        >
          <span className="text-lg">✨</span>
          <span>Our Story</span>
        </button>
        <button
          onClick={() => setActiveTab('calendar')}
          className={`flex flex-col items-center gap-1 font-semibold ${
            activeTab === 'calendar' ? 'text-bakery-gold' : 'text-bakery-brown-light'
