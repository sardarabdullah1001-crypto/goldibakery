              id="shopping-cart-toggle"
            >
              <ShoppingBag size={18} className="group-hover:animate-bounce" />
              <span className="text-xs font-bold tracking-wider uppercase hidden sm:inline">My Basket</span>
              {cartCount > 0 && (
