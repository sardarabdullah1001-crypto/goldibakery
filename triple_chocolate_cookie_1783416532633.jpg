    <header className="sticky top-0 z-40 w-full bg-bakery-cream-light/95 backdrop-blur-md border-b border-bakery-cream-dark transition-all duration-300" id="bakery-header">
      {/* Top micro announcement bar */}
      <div className="bg-bakery-brown-dark text-bakery-cream text-center py-1.5 px-4 text-xs tracking-wider flex justify-between items-center max-w-7xl mx-auto sm:px-6 lg:px-8">
        <span className="font-medium">✨ Micro-Batch Bakery • Pre-orders only (2 Days Prior)</span>
        <div className="hidden sm:flex items-center space-x-4">
          <a href="tel:03276930916" className="flex items-center hover:text-bakery-gold transition-colors">
            <Phone size={12} className="mr-1.5" />
            03276930916
          </a>
          <span className="flex items-center">
            <MapPin size={12} className="mr-1.5" />
            Classy Delivery & Pickup
          </span>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div className="flex justify-between items-center h-20">
          {/* Logo / Brand Name */}
          <button
            onClick={() => setActiveTab('menu')}
            className="flex items-center gap-3 cursor-pointer text-left focus:outline-none group"
            id="brand-logo-btn"
          >
            {/* Custom Braided Bread Logo SVG based on the user's logo */}
            <div className="w-12 h-12 flex-shrink-0 bg-bakery-cream-dark rounded-xl p-1 flex items-center justify-center border border-bakery-gold/20 group-hover:border-bakery-gold/50 transition-colors">
              <Logo className="w-10 h-10" />
            </div>
            <div>
              <span className="block font-serif text-xl tracking-wider font-extrabold uppercase text-bakery-brown-dark leading-none">
                Goldilocks
              </span>
              <span className="block font-sans text-[10px] tracking-widest text-bakery-gold font-bold uppercase mt-0.5">
                Micro-Bakery
              </span>
            </div>
          </button>

          {/* Center Navigation links */}
          <nav className="hidden md:flex space-x-1" id="main-navigation">
            <button
              onClick={() => setActiveTab('menu')}
              className={`px-5 py-2 rounded-full text-sm font-semibold tracking-wide transition-all ${
                activeTab === 'menu'
                  ? 'bg-bakery-brown-dark text-bakery-cream shadow-sm'
                  : 'text-bakery-brown-medium hover:text-bakery-brown-dark hover:bg-bakery-cream-dark/50'
              }`}
            >
              The Bakery Menu
            </button>
            <button
              onClick={() => setActiveTab('about')}
              className={`px-5 py-2 rounded-full text-sm font-semibold tracking-wide transition-all ${
                activeTab === 'about'
                  ? 'bg-bakery-brown-dark text-bakery-cream shadow-sm'
                  : 'text-bakery-brown-medium hover:text-bakery-brown-dark hover:bg-bakery-cream-dark/50'
              }`}
            >
              Our Story
            </button>
            <button
              onClick={() => setActiveTab('calendar')}
              className={`px-5 py-2 rounded-full text-sm font-semibold tracking-wide transition-all ${
                activeTab === 'calendar'
                  ? 'bg-bakery-brown-dark text-bakery-cream shadow-sm'
                  : 'text-bakery-brown-medium hover:text-bakery-brown-dark hover:bg-bakery-cream-dark/50'
              }`}
            >
              Pre-order Planner
            </button>
          </nav>

          {/* Right Action buttons */}
          <div className="flex items-center space-x-3">
            {/* Quick pre-order shortcut icon */}
            <button
              onClick={() => setActiveTab('calendar')}
              className="p-2.5 rounded-full border border-bakery-cream-dark text-bakery-brown-medium hover:text-bakery-brown-dark hover:bg-bakery-cream hover:border-bakery-gold/30 transition-all sm:flex hidden items-center gap-1.5 text-xs font-semibold"
              title="Pre-order Scheduler"
            >
              <CalendarIcon size={16} className="text-bakery-gold" />
