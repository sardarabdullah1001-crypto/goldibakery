                  {cartCount}
                </span>
              )}
            </button>
          </div>
        </div>
      </div>

      {/* Mobile navigation bottom bar */}
      <div className="flex md:hidden bg-bakery-cream-light border-t border-bakery-cream-dark justify-around py-3 px-2 text-center text-xs">
        <button
