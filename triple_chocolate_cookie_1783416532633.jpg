import { ShoppingBag, Calendar as CalendarIcon, Phone, MapPin } from 'lucide-react';
import Logo from './Logo';

interface NavbarProps {
  activeTab: 'menu' | 'about' | 'calendar';
  setActiveTab: (tab: 'menu' | 'about' | 'calendar') => void;
  cartCount: number;
  onOpenCart: () => void;
