          className={`flex flex-col items-center gap-1 font-semibold ${
            activeTab === 'menu' ? 'text-bakery-gold' : 'text-bakery-brown-light'
          }`}
        >
          <span className="text-lg">🍞</span>
          <span>Our Menu</span>
        </button>
        <button
          onClick={() => setActiveTab('about')}
          className={`flex flex-col items-center gap-1 font-semibold ${
            activeTab === 'about' ? 'text-bakery-gold' : 'text-bakery-brown-light'
